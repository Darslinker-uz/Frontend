# ============================================================
# DATABASE
# ============================================================
# Local: postgresql://user@localhost:5432/dbname
# Prod:  postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user@localhost:5432/darslinker"

# ============================================================
# NEXTAUTH (v5)
# ============================================================
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
# In production set to your full URL: https://darslinker.uz
AUTH_URL="http://localhost:3000"
# Set to "true" when behind a proxy (nginx, cloudflare, etc.)
AUTH_TRUST_HOST="true"

# ============================================================
# TELEGRAM BOT
# ============================================================
# Provider/Center bot — used by /center login (kurs egalari)
TELEGRAM_BOT_TOKEN="1234567890:AA..."
TELEGRAM_BOT_USERNAME="YourCenterBot"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="YourCenterBot"

# Student bot — used by /student login and rating verification (o'quvchilar)
TELEGRAM_STUDENT_BOT_TOKEN="1234567890:BB..."
TELEGRAM_STUDENT_BOT_USERNAME="YourStudentBot"
NEXT_PUBLIC_TELEGRAM_STUDENT_BOT_USERNAME="YourStudentBot"

# Secret for webhook authentication (any random string, 32+ chars)
# Set the same value when calling Telegram setWebhook with secret_token
TELEGRAM_WEBHOOK_SECRET="change-me-random-string-32-chars-min"

# Chat IDs for admin notifications (run @getidsbot to find IDs)
# Group where new leads/boosts/listings are announced
TELEGRAM_ADMIN_GROUP_ID="-100xxxxxxxxxx"
# Personal DM for critical notifications
TELEGRAM_SUPER_ADMIN_CHAT_ID="xxxxxxxxxx"

# ============================================================
# CRON / SCHEDULED TASKS
# ============================================================
# Secret header to protect /api/cron/* endpoints. Call with:
#   curl -H "X-Cron-Secret: $CRON_SECRET" https://darslinker.uz/api/cron/boost-expire
CRON_SECRET="change-me-random-string-32-chars-min"

# ============================================================
# UPLOADS
# ============================================================
# Directory where uploaded images are stored.
# Dev: leave empty (defaults to public/uploads/)
# Prod: set to persistent volume path, e.g. /var/darslinker/uploads
# Nginx should serve this path as /uploads/* (see nginx.conf)
UPLOADS_DIR=""

# ============================================================
# INITIAL ADMIN (used by prisma/seed-prod.ts)
# ============================================================
ADMIN_PHONE="+998901110000"
ADMIN_PASSWORD="CHANGE_ME_NOW"
ADMIN_NAME="Admin"

# ============================================================
# SEO / Webmaster verification (ixtiyoriy — qiymat bo'lsa <head>'ga qo'shiladi)
# ============================================================
# Google Search Console: TXT yoki HTML tag verification
GOOGLE_SITE_VERIFICATION=""
# Yandex Webmaster
YANDEX_VERIFICATION=""
# Bing Webmaster Tools
BING_SITE_VERIFICATION=""

# ============================================================
# NODE
# ============================================================
# Set to "production" in prod
NODE_ENV="development"
