generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  student
  provider
  admin
  assistant
}

// Kontent turlari (Manba + Blog)
enum ArticleType {
  lugat       // "X nima?" — atama tushuntirish
  qollanma    // "Qanday qilish kerak" — step-by-step
  sharh       // "Top X" yoki qiyosiy maqola
  savol       // FAQ — savol-javob
  blog        // Erkin format blog post
}

enum ArticleStatus {
  draft       // qoralama (admin panelda ko'rinadi, publik emas)
  published   // saytda chiqqan
}

enum ListingFormat {
  offline
  online
  video
  hybrid
}

enum ListingStatus {
  pending
  active
  paused
  rejected
}

enum AdmissionStatus {
  open
  closed
}

enum LeadStatus {
  new_lead
  contacted
  callback
  converted
  not_interested
  disputed
}

enum BoostType {
  a_class
  b_class
}

enum BoostStatus {
  pending
  active
  ended
  stopped
  rejected
}

enum PaymentType {
  topup
  lead
  boost
  refund
}

enum PaymentStatus {
  success
  pending
  cancelled
}

enum PaymentMethod {
  click
  payme
  uzcard
  humo
  internal
}

enum BalanceType {
  credit
  debit
}

enum HelpStatus {
  new_req
  answered
  closed
}

enum PartnerStatus {
  new_app
  in_progress
  accepted
  rejected
}

// ==================== MODELS ====================

model User {
  id              Int      @id @default(autoincrement())
  name            String
  centerName      String?  @map("center_name")
  phone           String   @unique
  email           String?
  passwordHash    String   @map("password_hash")
  role            Role     @default(student)
  telegramChatId  String?  @map("telegram_chat_id")
  balance         Int      @default(0)
  banned          Boolean  @default(false)
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  createdAt       DateTime @default(now()) @map("created_at")
  lastActiveAt    DateTime @default(now()) @map("last_active_at")

  listings           Listing[]
  payments           Payment[]
  balanceLogs        BalanceLog[]
  managers           Manager[]
  proposedCategories Category[] @relation("ProposedCategories")

  @@map("users")
}

model Manager {
  id             Int      @id @default(autoincrement())
  ownerId        Int      @map("owner_id") // parent teacher
  name           String
  phone          String
  telegramChatId String?  @map("telegram_chat_id")
  canReply       Boolean  @default(true) @map("can_reply")
  canManage      Boolean  @default(false) @map("can_manage")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("managers")
}

model CategoryGroup {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  slug            String     @unique
  description     String?
  icon            String?
  color           String?
  active          Boolean    @default(true)
  // Bosh sahifaning "Yo'nalishlar" katta grid'ida ko'rinadimi (alohida toggle)
  showOnHomepage  Boolean    @default(true) @map("show_on_homepage")
  order           Int        @default(0)
  categories      Category[]
  articles        Article[]

  @@map("category_groups")
}

model Category {
  id              Int       @id @default(autoincrement())
  groupId         Int       @map("group_id")
  name            String
  slug            String    @unique
  description     String?
  icon            String?
  color           String?
  active          Boolean   @default(true)
  // O'qituvchi yangi yo'nalish so'raganda — yo'nalish DB'ga yoziladi lekin
  // pendingApproval=true bo'lgani uchun publik sahifalarda ko'rinmaydi.
  // Admin tasdiqlasa false bo'ladi va yo'nalish faollashadi.
  pendingApproval Boolean   @default(false) @map("pending_approval")
  proposedById    Int?      @map("proposed_by_id")
  order           Int       @default(0)

  group     CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)
  proposer  User?         @relation("ProposedCategories", fields: [proposedById], references: [id], onDelete: SetNull)
  listings  Listing[]
  articles  Article[]

  @@unique([groupId, slug])
  @@index([groupId])
  @@index([pendingApproval])
  @@map("categories")
}

model Listing {
  id              Int             @id @default(autoincrement())
  userId          Int             @map("user_id")
  categoryId      Int             @map("category_id")
  title           String
  slug            String          @unique
  description     String?
  price           Int
  format          ListingFormat
  location        String?
  region          String?
  district        String?
  language        String          @default("uz")
  languages       String[]        @default([])
  duration        String?
  lessons         String[]        @default([])
  level           String?
  levels          String[]        @default([])
  studentLimit    Int?            @map("student_limit")
  schedule        String?
  certificate     Boolean         @default(false)
  demoLesson      Boolean         @default(false) @map("demo_lesson")
  discount        String?
  teacherName     String?         @map("teacher_name")
  teacherExperience String?       @map("teacher_experience")
  paymentType     String?         @map("payment_type")
  startDate       DateTime?       @map("start_date")
  admissionStatus AdmissionStatus @default(open) @map("admission_status")
  phone           String
  imageUrl        String?         @map("image_url")
  imagePosX       Int             @default(50) @map("image_pos_x")
  imagePosY       Int             @default(50) @map("image_pos_y")
  imageAPosX      Int             @default(50) @map("image_a_pos_x")
  imageAPosY      Int             @default(50) @map("image_a_pos_y")
  imageAMPosX     Int             @default(50) @map("image_am_pos_x")
  imageAMPosY     Int             @default(50) @map("image_am_pos_y")
  imageCPosX      Int             @default(50) @map("image_c_pos_x")
  imageCPosY      Int             @default(50) @map("image_c_pos_y")
  imageCMPosX     Int             @default(50) @map("image_cm_pos_x")
  imageCMPosY     Int             @default(50) @map("image_cm_pos_y")
  imageZoom       Int             @default(100) @map("image_zoom")
  imageAZoom      Int             @default(100) @map("image_a_zoom")
  imageAMZoom     Int             @default(100) @map("image_am_zoom")
  imageCZoom      Int             @default(100) @map("image_c_zoom")
  imageCMZoom     Int             @default(100) @map("image_cm_zoom")
  color           String?
  icon            String?
  views           Int             @default(0)
  status          ListingStatus   @default(pending)
  rejectReason    String?         @map("reject_reason")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  leads    Lead[]
  reviews  Review[]
  boosts   Boost[]
  ratings  Rating[]
  branches ListingLocation[]

  @@index([status])
  @@index([categoryId])
  @@map("listings")
}

model ListingLocation {
  id        Int      @id @default(autoincrement())
  listingId Int      @map("listing_id")
  region    String?
  district  String?
  address   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([region])
  @@map("listing_locations")
}

model Lead {
  id           Int        @id @default(autoincrement())
  listingId    Int        @map("listing_id")
  name         String
  phone        String
  message      String?
  status       LeadStatus @default(new_lead)
  note         String?
  botChatId    String?    @map("bot_chat_id")
  botMessageId Int?       @map("bot_message_id")
  createdAt    DateTime   @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  review  Review?

  @@unique([phone, listingId])
  @@index([listingId])
  @@index([status])
  @@map("leads")
}

model HelpLead {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String
  interest  String
  message   String?
  status    HelpStatus @default(new_req)
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("help_leads")
}

model PartnerApplication {
  id             Int           @id @default(autoincrement())
  name           String
  phone          String
  telegram       String?
  centerName     String        @map("center_name")
  category       String
  city           String
  studentsCount  String        @map("students_count")
  message        String?
  status         PartnerStatus @default(new_app)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("partner_applications")
}

model Review {
  id        Int      @id @default(autoincrement())
  listingId Int      @map("listing_id")
  leadId    Int      @unique @map("lead_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Boost {
  id           Int         @id @default(autoincrement())
  listingId    Int         @map("listing_id")
  type         BoostType   @default(a_class)
  pricePerDay  Int         @map("price_per_day")
  daysTotal    Int         @map("days_total")
  totalPaid    Int         @map("total_paid")
  startDate    DateTime    @map("start_date")
  endDate      DateTime    @map("end_date")
  status       BoostStatus @default(pending)
  views        Int         @default(0)
  leadsCount   Int         @default(0) @map("leads_count")
  rejectReason String?     @map("reject_reason")
  reviewedAt   DateTime?   @map("reviewed_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([listingId])
  @@map("boosts")
}

model Payment {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  amount      Int
  type        PaymentType
  status      PaymentStatus @default(pending)
  method      PaymentMethod @default(internal)
  description String?
  txnRef      String?       @map("txn_ref") // bog'liq tranzaksiya id (refund uchun)
  createdAt   DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("payments")
}

model BotPendingAction {
  id        Int      @id @default(autoincrement())
  chatId    String   @map("chat_id")
  leadId    Int      @map("lead_id")
  action    String // "note_for_contacted" | "reason_for_disputed"
  messageId Int      @map("message_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([chatId])
  @@map("bot_pending_actions")
}

model AuthCode {
  id        Int       @id @default(autoincrement())
  phone     String
  code      String
  chatId    String?   @map("chat_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([phone])
  @@index([code])
  @@map("auth_codes")
}

model BalanceLog {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  amount      Int
  type        BalanceType
  referenceId String?     @map("reference_id")
  note        String?
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("balance_logs")
}

model Rating {
  id        Int      @id @default(autoincrement())
  listingId Int      @map("listing_id")
  phone     String
  chatId    String?  @map("chat_id")
  stars     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, phone])
  @@index([listingId])
  @@index([phone])
  @@map("ratings")
}

// ===================================================================
// Manba — bilim maqolalari (lug'at + qo'llanma + sharh + FAQ).
// SEO va AEO uchun kontent ekosistemasi.
// ===================================================================
model Article {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  title       String
  excerpt     String?       // SEO description / qisqacha tavsif
  content     String        // Markdown matn
  type        ArticleType
  coverImage  String?       @map("cover_image")
  author      String?       // Muallif nomi (blog uchun ko'p ishlatiladi)
  readTime    String?       @map("read_time") // "5 daqiqa" — qo'lda yoki avtomatik hisoblansa
  status      ArticleStatus @default(draft)
  views       Int           @default(0)
  // Cross-linking taxonomiyaga (ixtiyoriy)
  categoryId  Int?          @map("category_id")
  groupId     Int?          @map("group_id")
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  category Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  group    CategoryGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([categoryId])
  @@index([groupId])
  @@map("articles")
}

// ===================================================================
// Region — Viloyat ro'yxati admin nazoratida.
// Listing.region (text) qoladi; Region.name bilan match qilamiz.
// `featured` flag — navbar megamenu "Mashhur shaharlar" ostida ko'rinishi uchun.
// `active` — viloyatni butunlay yashirish (kerak bo'lsa).
// ===================================================================
model Region {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  active    Boolean  @default(true)
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([featured])
  @@map("regions")
}

// ===================================================================
// FAQ — admin tomonidan boshqariladigan savol-javoblar.
// `page` field — qaysi sahifada chiqishi (hozir "home").
// `order` — drag-drop tartib.
// ===================================================================
model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  page      String   @default("home")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([page])
  @@map("faqs")
}
