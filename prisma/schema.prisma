generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  student
  provider
  admin
}

enum ListingFormat {
  offline
  online
  video
}

enum ListingStatus {
  pending
  active
  rejected
}

enum AdmissionStatus {
  open
  closed
}

enum LeadStatus {
  new_lead
  contacted
  converted
  disputed
}

enum BoostType {
  a_class
}

enum BoostStatus {
  active
  ended
}

enum PaymentType {
  topup
  lead
  boost
}

enum BalanceType {
  credit
  debit
}

// ==================== MODELS ====================

model User {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String   @unique
  passwordHash    String   @map("password_hash")
  role            Role     @default(student)
  telegramChatId  String?  @map("telegram_chat_id")
  balance         Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  listings    Listing[]
  payments    Payment[]
  balanceLogs BalanceLog[]

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  icon     String?
  slug     String    @unique
  listings Listing[]

  @@map("categories")
}

model Listing {
  id              Int             @id @default(autoincrement())
  userId          Int             @map("user_id")
  categoryId      Int             @map("category_id")
  title           String
  slug            String          @unique
  description     String?
  price           Int
  format          ListingFormat
  location        String?
  language        String          @default("uz")
  duration        String?
  startDate       DateTime?       @map("start_date")
  admissionStatus AdmissionStatus @default(open) @map("admission_status")
  phone           String
  imageUrl        String?         @map("image_url")
  status          ListingStatus   @default(pending)
  createdAt       DateTime        @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  leads    Lead[]
  reviews  Review[]
  boosts   Boost[]

  @@map("listings")
}

model Lead {
  id        Int        @id @default(autoincrement())
  listingId Int        @map("listing_id")
  name      String
  phone     String
  message   String?
  status    LeadStatus @default(new_lead)
  createdAt DateTime   @default(now()) @map("created_at")

  listing Listing  @relation(fields: [listingId], references: [id])
  review  Review?

  @@unique([phone, listingId])
  @@map("leads")
}

model Review {
  id        Int      @id @default(autoincrement())
  listingId Int      @map("listing_id")
  leadId    Int      @unique @map("lead_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id])
  lead    Lead    @relation(fields: [leadId], references: [id])

  @@map("reviews")
}

model Boost {
  id          Int         @id @default(autoincrement())
  listingId   Int         @map("listing_id")
  type        BoostType   @default(a_class)
  pricePerDay Int         @map("price_per_day")
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  status      BoostStatus @default(active)

  listing Listing @relation(fields: [listingId], references: [id])

  @@map("boosts")
}

model Payment {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  amount      Int
  type        PaymentType
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("payments")
}

model BalanceLog {
  id          Int         @id @default(autoincrement())
  userId      Int         @map("user_id")
  amount      Int
  type        BalanceType
  referenceId String?     @map("reference_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("balance_logs")
}
